<Window x:Class="CoinParkingSystem.Views.EntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EntryView"
        Height="600" Width="900"
        Background="#333333">

    <Grid Margin="20">

        <!-- UniformGrid with spacing and name for code-behind -->
        <UniformGrid x:Name="SlotGrid"
                     Rows="3" Columns="5"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     Margin="10">

            <!-- GLOBAL BUTTON STYLE -->
            <UniformGrid.Resources>
                <Style TargetType="Button">
                    <Setter Property="BorderBrush" Value="LimeGreen"/>
                    <Setter Property="BorderThickness" Value="5"/>
                    <Setter Property="Background" Value="#444"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontSize" Value="32"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="10"/>
                    <Setter Property="Height" Value="150"/>
                </Style>
            </UniformGrid.Resources>

            <!-- 15 SLOT BUTTONS -->
            <Button Content="1"  Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="1"/>
            <Button Content="2"  Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="2"/>
            <Button Content="3"  Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="3"/>
            <Button Content="4"  Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="4"/>
            <Button Content="5"  Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="5"/>

            <Button Content="6"  Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="6"/>
            <Button Content="7"  Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="7"/>
            <Button Content="8"  Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="8"/>
            <Button Content="9"  Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="9"/>
            <Button Content="10" Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="10"/>

            <Button Content="11" Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="11"/>
            <Button Content="12" Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="12"/>
            <Button Content="13" Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="13"/>
            <Button Content="14" Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="14"/>
            <Button Content="15" Click="SlotButton_Click" Command="{Binding SelectSlotCommand}" CommandParameter="15"/>

        </UniformGrid>
    </Grid>
</Window>
