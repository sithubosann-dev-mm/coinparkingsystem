<UserControl x:Class="CoinParkingSystem.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Height="450" Width="800"
             Background="#222222">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Mem2(Dashboard)" 
                       Foreground="White" 
                       FontSize="28" 
                       Margin="0,0,0,30"
                       HorizontalAlignment="Center"/>

            <Button Content="車両入庫 (Entry View)" 
                    Command="{Binding DataContext.MapsToEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Width="250" Height="60" 
                    Background="DarkGreen" Foreground="White" 
                    FontSize="18" FontWeight="Bold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>