<UserControl x:Class="CoinParkingSystem.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="1000"
             Height="650"
             Background="#1C1C1C">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111111" BorderBrush="#FFA500" BorderThickness="0,0,0,4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="55" Height="55" BorderBrush="#FFA500" BorderThickness="3" CornerRadius="28" Margin="0,0,15,0">
                    <TextBlock Text="P" Foreground="#FFA500" FontSize="32"
                               FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="COIN PARKING"
                           Foreground="#FFA500"
                           FontSize="34"
                           FontWeight="Black"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="45">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- MINI MAP -->
            <Border Grid.Column="0"
                    Background="#2D2D2D"
                    BorderBrush="#FFCC00"
                    BorderThickness="4"
                    CornerRadius="15"
                    Margin="20"
                    Padding="18">

                <StackPanel>
                    <TextBlock Text="PARKING MAP"
                               Foreground="#FFA500"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <UniformGrid Rows="3" Columns="5">

                        <UniformGrid.Resources>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#202020"/>
                                <Setter Property="BorderBrush" Value="#FFCC00"/>
                                <Setter Property="BorderThickness" Value="3"/>
                                <Setter Property="CornerRadius" Value="6"/>
                                <Setter Property="Margin" Value="6"/>
                                <Setter Property="Width" Value="62"/>
                                <Setter Property="Height" Value="62"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF3B30"/>
                                        <Setter Property="Background" Value="#3A2222"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>

                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FFA500"/>
                                <Setter Property="FontSize" Value="20"/>
                                <Setter Property="FontWeight" Value="Black"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </UniformGrid.Resources>

                        <Border DataContext="{Binding ParkingSlots[0]}">
                            <TextBlock Text="1"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[1]}">
                            <TextBlock Text="2"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[2]}">
                            <TextBlock Text="3"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[3]}">
                            <TextBlock Text="4"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[4]}">
                            <TextBlock Text="5"/>
                        </Border>

                        <Border DataContext="{Binding ParkingSlots[5]}">
                            <TextBlock Text="6"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[6]}">
                            <TextBlock Text="7"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[7]}">
                            <TextBlock Text="8"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[8]}">
                            <TextBlock Text="9"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[9]}">
                            <TextBlock Text="10"/>
                        </Border>

                        <Border DataContext="{Binding ParkingSlots[10]}">
                            <TextBlock Text="11"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[11]}">
                            <TextBlock Text="12"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[12]}">
                            <TextBlock Text="13"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[13]}">
                            <TextBlock Text="14"/>
                        </Border>
                        <Border DataContext="{Binding ParkingSlots[14]}">
                            <TextBlock Text="15"/>
                        </Border>
                    </UniformGrid>

                    <TextBlock Text="{Binding AvailableSlotsCount, StringFormat=Available: {0}}"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

            <!-- BUTTONS -->
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <Button Content="車両入庫 / ENTRY"
                        Width="330"
                        Height="80"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="DarkGreen"
                        BorderBrush="#FFA500"
                        BorderThickness="3"
                        Cursor="Hand"
                        Command="{Binding MapsToEntryCommand}"/>

                <Button Content="車両出庫 / EXIT"
                        Width="330"
                        Height="80"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#8B0000"
                        BorderBrush="#FFA500"
                        BorderThickness="3"
                        Cursor="Hand"
                        Margin="0,30,0,0"
                        Command="{Binding MapsToExitCommand}"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="コインパーキング管理システム"
                   Foreground="#888888"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
</UserControl>