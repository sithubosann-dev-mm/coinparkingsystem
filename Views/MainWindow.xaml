<Window x:Class="CoinParkingSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:v="clr-namespace:CoinParkingSystem.Views"
        xmlns:vm="clr-namespace:CoinParkingSystem.ViewModels"
        mc:Ignorable="d"
        Title="Coin Parking System" 
        Width="1024" Height="690"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <v:MainView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EntryViewModel}">
            <v:EntryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExitViewModel}">
            <v:ExitView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <ContentControl Content="{Binding CurrentView}"/>
    </Grid>
</Window>