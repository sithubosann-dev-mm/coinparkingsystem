<Window x:Class="CoinParkingSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CoinParkingSystem"
        
        xmlns:viewmodels="clr-namespace:CoinParkingSystem.ViewModels"
        xmlns:views="clr-namespace:CoinParkingSystem.Views"
        
        mc:Ignorable="d"
        Title="Coin Parking System" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:MainViewModel}">
            <views:MainView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:EntryViewModel}">
            <views:EntryView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:ExitViewModel}">
            <views:ExitView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <ContentControl Content="{Binding CurrentViewModel}" />
    </Grid>

</Window>