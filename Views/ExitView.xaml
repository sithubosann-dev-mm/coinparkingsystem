<UserControl x:Class="CoinParkingSystem.Views.ExitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:localConv="clr-namespace:CoinParkingSystem.Converters"
             mc:Ignorable="d"
             Width="1024" Height="700"
             Background="#1C1C1C">

    <UserControl.Resources>
        <localConv:SlotSelectionConverter x:Key="SlotSelectionConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0F5132"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111111" BorderBrush="#FFA500" BorderThickness="0,0,0,4">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0">
                    <Button Content="◀ 戻る " Command="{Binding CancelCommand}" Visibility="{Binding IsInputtingDetails, Converter={StaticResource BoolToVis}}" Width="130" Height="38" FontSize="14" FontWeight="Bold" Foreground="White" Background="#444444" BorderThickness="0" 
                            Margin="0,0,15,0" Cursor="Hand"/>

                    <Border Width="42" Height="42" BorderBrush="#FFA500" BorderThickness="3" CornerRadius="21" Margin="0,0,10,0">
                        <TextBlock Text="P" Foreground="#FFA500" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,2">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock Text="☀️ 昼間 (8:00~22:00)：" Foreground="white" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="30分 / 200円" Foreground="#FFCC00" FontSize="14" FontWeight="Black" VerticalAlignment="Center"/>

                        <Border BorderBrush="#444444" BorderThickness="1,0,0,0" Margin="15,2,15,2" Height="14"/>

                        <TextBlock Text="🌙 夜間 (22:00~8:00)：" Foreground="white" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="60分 / 100円" Foreground="#FFCC00" FontSize="14" FontWeight="Black" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="最大料金：" Foreground="White" FontSize="14" FontWeight="Black" VerticalAlignment="Center"/>
                        <TextBlock Text="月～金" Foreground="#888888" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0,0,0"/>
                        <TextBlock Text="700" Foreground="#FFCC00" FontSize="18" FontWeight="Black" VerticalAlignment="Center" Margin="3,0,0,0"/>
                        <TextBlock Text="円" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Bottom" Margin="1,0,0,2"/>

                        <Border BorderBrush="#444444" BorderThickness="1,0,0,0" Margin="15,2,15,2" Height="14"/>

                        <TextBlock Text="土日祝" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="1,200" Foreground="#FFCC00" FontSize="18" FontWeight="Black" VerticalAlignment="Center" Margin="3,0,0,0"/>
                        <TextBlock Text="円" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Bottom" Margin="1,0,0,2"/>
                    </StackPanel>
                </StackPanel>

                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0" 
                        Background="#222222" BorderBrush="#888888" BorderThickness="1" CornerRadius="6" Padding="10,5,10,5">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📞緊急連絡先：" Foreground="#888888" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="XXXX-XXX-XXX" Foreground="#FFA500" FontSize="14" FontWeight="Black" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="30,5,30,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2D2D2D" BorderBrush="#FFCC00" BorderThickness="4" CornerRadius="15" Margin="10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="PARKING MAP" Foreground="#FFA500" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding SharedParkingSlots}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="3" Columns="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="65" Height="65" Margin="6" CornerRadius="8" BorderThickness="3.5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#FFCC00"/>
                                            <Setter Property="Background" Value="#202020"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOccupied}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#FF3B30"/>
                                                    <Setter Property="Background" Value="#3A2222"/>
                                                </DataTrigger>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource SlotSelectionConverter}">
                                                            <Binding Path="SlotNumber"/>
                                                            <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.SlotNumberInput"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="#FF3B30"/>
                                                    <Setter Property="Background" Value="#551A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SlotNumber}" Foreground="#FFA500" FontSize="22" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Grid.Row="2" HorizontalAlignment="Center" Margin="0,50,0,0" Foreground="White" FontSize="12" FontWeight="Bold" Text="© Copyright TEAM1"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#2D2D2D" BorderBrush="#FFA500" BorderThickness="4" CornerRadius="15" Margin="10" Padding="20,10,20,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="75"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="#FFCC00" BorderThickness="2" CornerRadius="12" Padding="15" Margin="0,2,0,10">
                        <StackPanel VerticalAlignment="Top">
                            <TextBlock Text="【 領収書 】" Foreground="#FFCC00" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding SlotNumberInput, StringFormat=駐車番号 (Slot No) :  No. {0}}" Foreground="White" FontSize="15" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding EntryTimeDisplay, StringFormat=入庫時間 (Start)   :  {0}}" Foreground="White" FontSize="15" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding ExitTimeDisplay, StringFormat=出庫時間 (End)     :  {0}}" Foreground="White" FontSize="15" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding DurationDisplay, StringFormat=駐車時間 (Time)    :  {0}}" Foreground="White" FontSize="15" Margin="0,0,0,5"/>

                            <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,3,0,5"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="料金精算 : " Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding FeeResultDisplay}" Foreground="#FFCC00" FontSize="30" FontWeight="Black" Margin="5,0,0,0"/>
                                <TextBlock Text=" 円" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,5,0,2">
                        <TextBlock Text="支払い方法" Foreground="#FFA500" FontSize="14" FontWeight="Bold"/>
                        <ComboBox SelectedItem="{Binding PaymentMethod, Mode=TwoWay}" SelectedIndex="0" Background="#1A1A1A" Foreground="Black" BorderBrush="#FFCC00" BorderThickness="2" FontSize="16" Padding="4" Margin="0,2,0,0">
                            <ComboBoxItem Content="現金"/>
                            <ComboBoxItem Content="クレジットカード"/>
                            <ComboBoxItem Content="QR決済"/>
                            <ComboBoxItem Content="交通系電子マネー"/>
                        </ComboBox>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="#FFCC00" BorderThickness="2" CornerRadius="12" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding PaymentResult}" 
                                           Foreground="#FFCC00" FontSize="13" FontWeight="Bold" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                                           TextAlignment="Center" TextWrapping="Wrap"/>

                                <StackPanel Grid.Row="1" Margin="0,10,0,0" Visibility="{Binding IsCashSelectedVisibility}">
                                    <TextBlock Text="投入金額 (Insert Cash):" Foreground="#FFA500" FontSize="13" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding CashInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#111111" Foreground="#FFCC00" BorderBrush="#FFA500" BorderThickness="2" 
                                             FontSize="20" FontWeight="Bold" Padding="4" HorizontalContentAlignment="Center" Focusable="True"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" VerticalAlignment="Bottom" Margin="0,10,0,2">
                            <Button Content="料金確認" Command="{Binding CalculateFeeCommand}" Style="{StaticResource ExitButtonStyle}" Background="Transparent" BorderBrush="#FFCC00" BorderThickness="2" Foreground="#FFCC00" HorizontalAlignment="Left" Width="130"/>
                            <Button Content="支払い" Command="{Binding PayCommand}" Style="{StaticResource ExitButtonStyle}" HorizontalAlignment="Right" Width="130"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>